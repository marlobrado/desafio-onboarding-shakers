{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.
  - picker_type: {String} type of picker to dispay


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
    picker_type: picker_type
  %}
{% endcomment %}
{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    assign swatch_focal_point = null
    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = value.swatch.image.presentation.focal_point
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = null
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- capture input_id -%}
    {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
  {%- endcapture -%}

  {%- capture input_name -%}
    {{ option.name }}-{{ option.position }}
  {%- endcapture -%}

  {%- capture input_dataset -%}
    data-product-url="{{ value.product_url }}"
    data-option-value-id="{{ value.id }}"
  {%- endcapture -%}

  {%- capture label_unavailable -%}
    <span class="visually-hidden label-unavailable">
      {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
    </span>
  {%- endcapture -%}

  {%- if picker_type == 'swatch' -%}
    {%- capture help_text -%}
      <span class="visually-hidden">{{ value | escape }}</span>
      {{ label_unavailable }}
    {%- endcapture -%}
    {%
      render 'swatch-input',
      id: input_id,
      name: input_name,
      value: value | escape,
      swatch: value.swatch,
      product_form_id: product_form_id,
      checked: value.selected,
      visually_disabled: option_disabled,
      shape: block.settings.swatch_shape,
      help_text: help_text,
      additional_props: input_dataset
    %}
  {%- elsif picker_type == 'button' -%}
    {%- liquid
      assign button_color = blank
      assign button_background_style = blank
      if option.name contains 'Color' or option.name contains 'Cor'
        assign color_swatch_rows = settings.color_swatch_config | newline_to_br | split: '<br />'
        assign current_value = value | strip | downcase

        for color_row in color_swatch_rows
          assign color_row = color_row | strip
          if color_row != blank and color_row contains ':'
            assign color_parts = color_row | split: ':'
            assign color_name = color_parts[0] | strip | downcase

            if color_name == current_value
              assign button_color = color_parts[1] | strip
              break
            endif
          endif
        endfor

        if button_color != blank
          if button_color contains '/'
            assign split_colors = button_color | split: '/'
            assign left_color = split_colors[0] | strip
            assign right_color = split_colors[1] | default: split_colors[0] | strip
            assign button_background_style = 'background: linear-gradient(90deg, '
            assign button_background_style = button_background_style | append: left_color
            assign button_background_style = button_background_style | append: ' 0%, '
            assign button_background_style = button_background_style | append: left_color
            assign button_background_style = button_background_style | append: ' 50%, '
            assign button_background_style = button_background_style | append: right_color
            assign button_background_style = button_background_style | append: ' 50%, '
            assign button_background_style = button_background_style | append: right_color
            assign button_background_style = button_background_style | append: ' 100%) !important; color: #fff !important; text-shadow: 0 0 2px rgba(0, 0, 0, 0.9), 0 0 1px rgba(0, 0, 0, 0.9); border-color: rgba(0, 0, 0, 0.35) !important;'
          else
            assign button_background_style = 'background-color: '
            assign button_background_style = button_background_style | append: button_color
            assign button_background_style = button_background_style | append: ' !important; color: #fff !important; text-shadow: 0 0 2px rgba(0, 0, 0, 0.9), 0 0 1px rgba(0, 0, 0, 0.9); border-color: rgba(0, 0, 0, 0.35) !important;'
          endif
        endif
      endif
    -%}
    <input
      type="radio"
      id="{{ input_id }}"
      name="{{ input_name | escape }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
      {{ input_dataset }}
    >
    <label
      for="{{ input_id }}"
      {% if button_background_style != blank %}
        style="{{ button_background_style }}"
      {% endif %}
    >
      {{ value -}}
      {{ label_unavailable }}
    </label>
  {%- elsif picker_type == 'dropdown' or picker_type == 'swatch_dropdown' -%}
    <option
      id="{{ input_id }}"
      value="{{ value | escape }}"
      {% if value.selected %}
        selected="selected"
      {% endif %}
      {% if swatch_value and picker_type == 'swatch_dropdown' %}
        data-option-swatch-value="{{ swatch_value }}"
        {% if swatch_focal_point %}
          data-option-swatch-focal-point="{{ swatch_focal_point }}"
        {% endif %}
      {% endif %}
      {{ input_dataset }}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}
